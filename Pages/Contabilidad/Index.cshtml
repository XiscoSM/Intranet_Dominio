@page
@model Intranet.Pages.Contabilidad.IndexModel
@{
    ViewData["Title"] = "Cuadre de Cajas";
}

<div class="hero" style="padding-top:18px">
    <h1>Cuadre de Cajas</h1>
    <p>Selecciona la fecha y abre el informe de la tienda</p>
</div>

<form method="get" class="toolbar" style="justify-content:center">
    <label>Fecha <input type="date" name="v1" value="@Fmt.FechaInput(Model.Fecha)" /></label>
    <button type="submit">Aplicar</button>
</form>

<table class="informe" style="max-width:860px; margin:0 auto 20px">
    <tr class="CabeceraTablas">
        <td>Tienda</td>
        <td>Cuadre Cajas</td>
        <td>Resumen Ventas</td>
        <td>Tarjetas</td>
        <td>Informe Cierre</td>
        <td>Balanzas</td>
    </tr>
    @foreach (var a in Model.Almacenes)
    {
        <tr>
            <td><strong>@a.Alm</strong> — @a.DescAlm</td>
            <td class="ctr"><a asp-page="CuadreCajas" asp-route-v1="@Model.Fecha" asp-route-v2="@a.Alm">Abrir</a></td>
            <td class="ctr"><a asp-page="/Restringida/ResumenVentas" asp-route-v1="@Model.Fecha" asp-route-v2="@a.Alm">Abrir</a></td>
            <td class="ctr"><a asp-page="/Restringida/TarjetasCredito" asp-route-v1="@Model.Fecha" asp-route-v2="@a.Alm">Abrir</a></td>
            <td class="ctr"><a asp-page="InformeCierre" asp-route-p2="@Model.Fecha" asp-route-v2="@a.Alm">Abrir</a></td>
            <td class="ctr"><a asp-page="InformeBalanzas" asp-route-p2="@Model.Fecha" asp-route-v2="@a.Alm">Abrir</a></td>
        </tr>
    }
</table>
